{
  "name": "vscode-ail-chat",
  "displayName": "ail Chat",
  "description": "Streaming chat interface for ail pipelines",
  "version": "0.1.1",
  "publisher": "alexchesser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchesser/ail"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:ail-chat.chatView",
    "workspaceContains:.ail.yaml",
    "workspaceContains:.ail/*.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ail-chat-sidebar",
          "title": "ail Chat",
          "icon": "images/ail-sidebar.svg"
        }
      ]
    },
    "views": {
      "ail-chat-sidebar": [
        {
          "id": "ail-chat.chatView",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "ail-chat.historyView",
          "name": "Run History",
          "when": "ail-chat.panelVisible"
        },
        {
          "id": "ail-chat.stepsView",
          "name": "Pipeline Steps",
          "when": "ail-chat.panelVisible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ail-chat.toggleInfoPanel",
          "when": "view == ail-chat.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ail Chat",
      "properties": {
        "ail-chat.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ail binary. Leave empty to use the bundled binary or search PATH."
        },
        "ail-chat.defaultPipeline": {
          "type": "string",
          "default": "",
          "description": "Path to the default pipeline file. Leave empty for automatic discovery."
        },
        "ail-chat.headless": {
          "type": "boolean",
          "default": false,
          "description": "Run ail with --headless (--dangerously-skip-permissions). Use only in trusted workspaces."
        },
        "ail-chat.updateCheckIntervalDays": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 30,
          "description": "How often (in days) to check for new ail releases at activation. 0 = check every activation. Set to a larger value to reduce GitHub API traffic."
        }
      }
    },
    "commands": [
      {
        "command": "ail-chat.open",
        "title": "ail Chat: Open Chat",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.newSession",
        "title": "ail Chat: New Session",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.openPipelineGraph",
        "title": "ail Chat: Open Pipeline Graph",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.toggleInfoPanel",
        "title": "ail Chat: Toggle Run History & Steps Panel",
        "category": "ail Chat",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "ail-chat.openRunLog",
        "title": "ail Chat: Open Run Log",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.openStep",
        "title": "ail Chat: Go to Step",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.installBinary",
        "title": "ail Chat: Install CLI Binary to PATH",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.checkForUpdates",
        "title": "ail Chat: Check for ail Updates",
        "category": "ail Chat"
      },
      {
        "command": "ail-chat.useAnyway",
        "title": "ail Chat: Toggle \"Use Anyway\" Override (Bypass Minimum Version)",
        "category": "ail Chat"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "compile": "tsc -p ./",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "check": "npm run compile && npm run lint && npm test"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.27.5",
    "eslint": "^8.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@vscode/codicons": "^0.0.45",
    "@xyflow/react": "^12.10.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "yaml": "^2.8.3"
  },
  "config": {
    "ailMinVersion": "0.1.0",
    "ailBundledVersion": "0.1.2"
  }
}
