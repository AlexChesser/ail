{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ail-log",
  "scopeName": "source.ail-log",
  "fileTypes": ["ail-log"],
  "patterns": [
    { "include": "#version-header" },
    { "include": "#turn-header" },
    { "include": "#thinking-block" },
    { "include": "#tool-call-block" },
    { "include": "#tool-result-block" },
    { "include": "#stdio-block" },
    { "include": "#cost-line" },
    { "include": "#error-callout" },
    { "include": "#markdown-content" }
  ],
  "repository": {
    "version-header": {
      "name": "meta.version.ail-log",
      "match": "^ail-log/1$",
      "captures": {
        "0": { "name": "keyword.other.ail-log" }
      }
    },
    "turn-header": {
      "name": "markup.heading.ail-log",
      "match": "^## Turn \\d+ — `[^`]+`$",
      "captures": {
        "0": { "name": "markup.heading.2.markdown" }
      }
    },
    "thinking-block": {
      "name": "meta.directive.thinking.ail-log",
      "begin": "^:::thinking\\s*$",
      "end": "^:::\\s*$",
      "beginCaptures": {
        "0": { "name": "markup.raw.ail-log" }
      },
      "endCaptures": {
        "0": { "name": "markup.raw.ail-log" }
      },
      "contentName": "markup.quote.ail-log",
      "patterns": [
        { "include": "#markdown-inline" }
      ],
      "foldingStartMarker": "^:::thinking",
      "foldingEndMarker": "^:::\\s*$"
    },
    "tool-call-block": {
      "name": "meta.directive.tool-call.ail-log",
      "begin": "^:::tool-call\\s+name=\"([^\"]+)\".*$",
      "end": "^:::\\s*$",
      "beginCaptures": {
        "0": { "name": "markup.raw.ail-log" },
        "1": { "name": "entity.name.function.ail-log" }
      },
      "endCaptures": {
        "0": { "name": "markup.raw.ail-log" }
      },
      "contentName": "source.json",
      "patterns": [
        { "include": "source.json" }
      ],
      "foldingStartMarker": "^:::tool-call",
      "foldingEndMarker": "^:::\\s*$"
    },
    "tool-result-block": {
      "name": "meta.directive.tool-result.ail-log",
      "begin": "^:::tool-result\\s+name=\"([^\"]+)\".*$",
      "end": "^:::\\s*$",
      "beginCaptures": {
        "0": { "name": "markup.raw.ail-log" },
        "1": { "name": "entity.name.function.ail-log" }
      },
      "endCaptures": {
        "0": { "name": "markup.raw.ail-log" }
      },
      "contentName": "markup.quote.ail-log",
      "patterns": [
        { "include": "#markdown-inline" }
      ],
      "foldingStartMarker": "^:::tool-result",
      "foldingEndMarker": "^:::\\s*$"
    },
    "stdio-block": {
      "name": "meta.directive.stdio.ail-log",
      "begin": "^:::stdio\\s+stream=\"(stdout|stderr)\".*$",
      "end": "^:::\\s*$",
      "beginCaptures": {
        "0": { "name": "markup.raw.ail-log" },
        "1": { "name": "constant.language.ail-log" }
      },
      "endCaptures": {
        "0": { "name": "markup.raw.ail-log" }
      },
      "contentName": "markup.quote.ail-log",
      "foldingStartMarker": "^:::stdio",
      "foldingEndMarker": "^:::\\s*$"
    },
    "cost-line": {
      "name": "meta.cost.ail-log",
      "match": "^_Cost: \\$[0-9]+\\.[0-9]{4} \\| \\d+in / \\d+out tokens_$",
      "captures": {
        "0": { "name": "markup.italic.ail-log" }
      }
    },
    "error-callout": {
      "name": "markup.quote.ail-log",
      "begin": "^> \\[!WARNING\\]$",
      "end": "^(?!>)",
      "patterns": [
        {
          "match": "^> \\*\\*Step failed:\\*\\*",
          "captures": {
            "0": { "name": "markup.bold.ail-log" }
          }
        },
        {
          "match": "^>",
          "name": "punctuation.definition.quote.markdown"
        }
      ]
    },
    "markdown-content": {
      "patterns": [
        { "include": "#markdown-headings" },
        { "include": "#markdown-lists" },
        { "include": "#markdown-code-blocks" },
        { "include": "#markdown-inline" }
      ]
    },
    "markdown-headings": {
      "match": "^#{1,6}\\s+.*$",
      "name": "markup.heading.markdown"
    },
    "markdown-lists": {
      "patterns": [
        {
          "match": "^\\s*[-*+]\\s+",
          "name": "markup.list.unnumbered.markdown"
        },
        {
          "match": "^\\s*[0-9]+\\.\\s+",
          "name": "markup.list.numbered.markdown"
        }
      ]
    },
    "markdown-code-blocks": {
      "name": "markup.fenced_code.markdown",
      "begin": "^\\s*```[a-z]*$",
      "end": "^\\s*```\\s*$",
      "contentName": "markup.raw.ail-log"
    },
    "markdown-inline": {
      "patterns": [
        {
          "match": "\\*\\*[^*]+\\*\\*",
          "name": "markup.bold.markdown"
        },
        {
          "match": "\\*[^*]+\\*",
          "name": "markup.italic.markdown"
        },
        {
          "match": "`[^`]+`",
          "name": "markup.inline.raw.markdown"
        },
        {
          "match": "\\[[^\\]]+\\]\\([^)]+\\)",
          "name": "markup.underline.link.markdown"
        }
      ]
    }
  }
}
