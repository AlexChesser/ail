{
  "name": "vscode-ail",
  "displayName": "ail — AI Pipeline Orchestrator",
  "description": "Run and monitor ail pipelines from VS Code",
  "version": "0.1.0",
  "publisher": "alexchesser",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchesser/ail"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.ail.yaml",
    "workspaceContains:.ail/*.yaml"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ail-sidebar",
          "title": "AIL Pipelines",
          "icon": "images/ail-sidebar.svg"
        }
      ]
    },
    "configuration": {
      "title": "ail",
      "properties": {
        "ail.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ail binary. Leave empty to use the bundled binary."
        },
        "ail.defaultPipeline": {
          "type": "string",
          "default": "",
          "description": "Path to the default pipeline file. Leave empty for automatic discovery."
        }
      }
    },
    "commands": [
      {
        "command": "ail.validatePipeline",
        "title": "Ail: Validate Pipeline",
        "category": "ail"
      },
      {
        "command": "ail.runPipeline",
        "title": "Ail: Run Pipeline",
        "category": "ail"
      },
      {
        "command": "ail.stopPipeline",
        "title": "Ail: Stop Pipeline",
        "category": "ail"
      },
      {
        "command": "ail.materializePipeline",
        "title": "Ail: Inspect Resolved Pipeline",
        "category": "ail"
      },
      {
        "command": "ail.refreshExplorer",
        "title": "Ail: Refresh Pipeline Explorer",
        "category": "ail",
        "icon": "$(refresh)"
      },
      {
        "command": "ail.runFromTree",
        "title": "Run Pipeline",
        "category": "ail",
        "icon": "$(play)"
      },
      {
        "command": "ail.validateFromTree",
        "title": "Validate Pipeline",
        "category": "ail",
        "icon": "$(check)"
      },
      {
        "command": "ail.runWithPrompt",
        "title": "Ail: Run with Prompt",
        "category": "ail"
      },
      {
        "command": "ail.setActivePipeline",
        "title": "Set as Active Pipeline",
        "category": "ail"
      },
      {
        "command": "ail.browsePipeline",
        "title": "Ail: Browse for Pipeline",
        "category": "ail",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ail.openPipelineFile",
        "title": "Open File",
        "category": "ail",
        "icon": "$(go-to-file)"
      }
    ],
    "views": {
      "ail-sidebar": [
        {
          "id": "ail.chatView",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "ail.pipelineExplorer",
          "name": "Pipelines"
        },
        {
          "id": "ail.stepsView",
          "name": "Steps"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "ail.validatePipeline",
          "when": "resourceExtname == .yaml && resourceFilename =~ /\\.ail\\.yaml$/",
          "group": "navigation"
        },
        {
          "command": "ail.runPipeline",
          "when": "resourceExtname == .yaml && resourceFilename =~ /\\.ail\\.yaml$/",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "ail.browsePipeline",
          "when": "view == ail.pipelineExplorer",
          "group": "navigation"
        },
        {
          "command": "ail.refreshExplorer",
          "when": "view == ail.pipelineExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ail.runFromTree",
          "when": "viewItem == ailPipeline || viewItem == ailActivePipeline",
          "group": "inline@1"
        },
        {
          "command": "ail.openPipelineFile",
          "when": "viewItem == ailPipeline || viewItem == ailActivePipeline",
          "group": "inline@2"
        },
        {
          "command": "ail.validateFromTree",
          "when": "viewItem == ailPipeline || viewItem == ailActivePipeline",
          "group": "1_actions@1"
        },
        {
          "command": "ail.openPipelineFile",
          "when": "viewItem == ailPipeline || viewItem == ailActivePipeline",
          "group": "1_actions@2"
        }
      ]
    },
    "languages": [
      {
        "id": "ail-pipeline",
        "aliases": [
          "AIL Pipeline"
        ],
        "extensions": [
          ".ail.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "compile": "tsc -p ./",
    "watch": "node esbuild.js --watch",
    "test": "npm run compile && node out/test/binary.test.js && node out/test/ndjson.test.js && node out/test/pipeline-tree.test.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.27.5",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "config": {
    "ailMinVersion": "0.1.0"
  }
}
